Algoritmo "ATIVIDADE 24"
// Disciplina   : [Linguagem e Lógica de Programaçăo]

Var
// Seçăo de Declaraçőes das variáveis 
num, soma: real
contador: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva ("Digite um número: ")
leia (num)

soma<- 0
contador<- 0

enquanto num <> 0 faca
 soma <- soma + num
 contador <- contador + 1
 leia (num)
 fimenquanto
 
 escreval ("Quantidade: ", contador)
 escreval ("Soma dos números: ", soma)

Fimalgoritmo