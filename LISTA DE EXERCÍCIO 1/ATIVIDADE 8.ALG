Algoritmo "ATIVIDADE 8"

Var
   numeroUm, numeroDois, resultadoEle : real

Inicio

      Escreva("Digite o Primeiro número:")
      Leia(numeroUm)
      
      Escreva("Digite o segundo número:")
      Leia(numeroDois)
      
      resultadoEle <- numeroUm ^ numeroDois
      
      
      Escreval("A potęncia é: ", resultadoEle)
Fimalgoritmo