Algoritmo "ATIVIDADE 4"

Var
   base, altura, area : real


Inicio
      Escreva ("Digite a base do retangulo:")
      Leia(base)
      
      Escreva("Digite a altura do retangulo:")
      Leia(altura)
      
      area <- base * altura
      
      Escreval ("A area do retangulo é: ", area:5:2)


Fimalgoritmo