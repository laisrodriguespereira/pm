Algoritmo "ATIVIDADE 5"

Var
   idademes, idadeano : inteiro
   idadedias: real


Inicio

      Escreva("Quantos anos vocę tem?")
      Leia(idadeano)
      
      idademes <- idadeano * 12
      idadedias <- idadeano * 365
      
      Escreval("Em meses de idade vocę tem:", idademes)
      
      Escreval("Em dias de idade vocę tem:", idadedias)


Fimalgoritmo