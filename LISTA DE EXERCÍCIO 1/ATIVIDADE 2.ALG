Algoritmo "ATIVIDADE 2"

Var
   primeiro_nu, segundo_nu, total: inteiro

Inicio
   Escreval("Informe o primeiro número:")
   Leia(primeiro_nu)

   Escreval("Informe o segundo número:")
   Leia(segundo_nu)


   total <- (primeiro_nu + segundo_nu)

   Escreval ("A soma é", total)
Fimalgoritmo