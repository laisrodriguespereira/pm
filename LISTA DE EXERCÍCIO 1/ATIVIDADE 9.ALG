Algoritmo "ATIVIDADE 9"

Var
   numero :inteiro

Inicio

      Escreva("Digite um n·mero inteiro: ")

      Leia(numero)
      
      se(numero % 2 = 0 ) entao
      
      escreval("O numero", numero , " ķ par")
      senao
      escreval("O numero", numero ," ķ impar")
      
      fimse
Fimalgoritmo