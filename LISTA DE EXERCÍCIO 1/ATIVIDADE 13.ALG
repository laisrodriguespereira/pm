Algoritmo "ATIVIDADE 13"

Var

   numero : inteiro
   
Inicio

  Escreva("Escreva um Número Inteiro: ")
  Leia(numero)

  se(numero > 0) entao
  Escreval ("Ele é positivo")

  senao
  
  se(numero = 0)entao
  Escreval("Ele é zero")

  senao
  
  se(numero < 0)entao
  Escreval("Ele é negativo")

  Fimse
  Fimse
  Fimse
Fimalgoritmo