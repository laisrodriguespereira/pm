Algoritmo "ATIVIDADE 15"

Var

   numero : real
   
Inicio

   Escreva("Digite um número que seteja entre 10 e 50: ")
   Leia(numero)

   se (numero >=10) e (numero <= 50) entao
   Escreval("Esse número está entre 10 e 50!")
   senao
   EScreval("Esse numero NĂO está entre 10 e 50")

fimse
Fimalgoritmo