Algoritmo "ATIVIDADE 14"

Var

  valor, valorfinal: real
  


Inicio

  Escreva("Digite o valor da compra: ")
  Leia(valor)

  se (valor > 100)entao

  valorfinal <- valor * 0.9

  Escreval("O valor final da compra com desconto foi: ", valorfinal)

  senao
  
  valorfinal <- valor
  
   Escreval("O valor final da compra foi de: ", valorfinal)
fimse

Fimalgoritmo