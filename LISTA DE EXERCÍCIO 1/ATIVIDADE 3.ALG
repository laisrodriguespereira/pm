Algoritmo "ATIVIDADE 3"

Var
        numero, antecessor, sucessor : inteiro
Inicio

  Escreva ("Digite um número inteiro: ")
  Leia (numero)
  
  antecessor <- numero -1
  sucessor <- numero +1
  
  Escreval ("O seu número é:", numero)
  Escreval ("O antecessor é:", antecessor)
  Escreval ("O sucessor é:", sucessor)

Fimalgoritmo