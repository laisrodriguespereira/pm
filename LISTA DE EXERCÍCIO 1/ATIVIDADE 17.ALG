Algoritmo "ATIVIDADE 17"

Var
login, senha: caractere


Inicio

      Escreva("Digite o nome de usuário: ")
      leia(login)
      
      Escreva("Digite sua senha: ")
      leia(senha)
      
      se (login = "admin") e (senha = "1234")entao
      Escreval("Seja bem-vindo ", login)
      senao
      Escreval("Acesso Negado!")
      fimse

Fimalgoritmo